{
  "openapi": "3.0.3",
  "info": {
    "title": "TuneVault API",
    "description": "REST API for TuneVault — a media-sharing platform supporting audio/video uploads, playlists, favorites, play history, social follows, shares, and notifications.",
    "version": "1.0.0",
    "contact": {
      "name": "TuneVault"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5237",
      "description": "Local development (HTTP)"
    }
  ],
  "security": [],
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer",
        "bearerFormat": "JWT",
        "description": "JWT bearer token obtained from /api/auth/login or /api/auth/register"
      }
    },
    "schemas": {
      "RegisterRequest": {
        "type": "object",
        "required": ["email", "password", "displayName"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "minLength": 8,
            "example": "P@ssw0rd!"
          },
          "displayName": {
            "type": "string",
            "example": "John Doe"
          }
        }
      },
      "RegisterResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "token": {
            "type": "string",
            "description": "JWT access token"
          }
        }
      },
      "LoginRequest": {
        "type": "object",
        "required": ["email", "password"],
        "properties": {
          "email": {
            "type": "string",
            "format": "email",
            "example": "user@example.com"
          },
          "password": {
            "type": "string",
            "example": "P@ssw0rd!"
          }
        }
      },
      "LoginResponse": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "email": {
            "type": "string",
            "format": "email"
          },
          "token": {
            "type": "string",
            "description": "JWT access token"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MediaFileType": {
        "type": "string",
        "enum": ["Audio", "Video"],
        "description": "Type of the media file"
      },
      "MediaItemDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "genre": {
            "type": "string",
            "nullable": true
          },
          "filePath": {
            "type": "string"
          },
          "fileType": {
            "$ref": "#/components/schemas/MediaFileType"
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds"
          },
          "description": {
            "type": "string",
            "nullable": true
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "MediaItemSummaryDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds"
          },
          "fileType": {
            "type": "string",
            "description": "Audio or Video"
          },
          "streamUrl": {
            "type": "string",
            "description": "URL to stream this media item"
          }
        }
      },
      "CreateMediaItemRequest": {
        "type": "object",
        "required": ["title", "artist", "filePath", "fileType", "duration"],
        "properties": {
          "title": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "genre": {
            "type": "string",
            "nullable": true
          },
          "filePath": {
            "type": "string"
          },
          "fileType": {
            "$ref": "#/components/schemas/MediaFileType"
          },
          "duration": {
            "type": "integer"
          },
          "description": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PagedMediaItemSummary": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaItemSummaryDto"
            }
          },
          "totalCount": {
            "type": "integer"
          },
          "pageNumber": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          }
        }
      },
      "PlaylistDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "isPublic": {
            "type": "boolean"
          },
          "trackCount": {
            "type": "integer"
          }
        }
      },
      "PlaylistDetailDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "isPublic": {
            "type": "boolean"
          },
          "ownerName": {
            "type": "string"
          },
          "tracks": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/MediaItemSummaryDto"
            }
          }
        }
      },
      "CreatePlaylistRequest": {
        "type": "object",
        "required": ["title"],
        "properties": {
          "title": {
            "type": "string",
            "maxLength": 200,
            "example": "My Favourite Tracks"
          },
          "isPublic": {
            "type": "boolean",
            "default": false
          }
        }
      },
      "AddTrackRequest": {
        "type": "object",
        "required": ["mediaItemId"],
        "properties": {
          "mediaItemId": {
            "type": "string",
            "format": "uuid"
          }
        }
      },
      "ShareRequest": {
        "type": "object",
        "properties": {
          "receiverId": {
            "type": "string",
            "format": "uuid",
            "description": "Recipient user ID (either receiverId or receiverEmail must be provided)"
          },
          "receiverEmail": {
            "type": "string",
            "format": "email",
            "description": "Recipient email (either receiverId or receiverEmail must be provided)"
          },
          "mediaItemId": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "Share a media item (exactly one of mediaItemId or playlistId must be set)"
          },
          "playlistId": {
            "type": "string",
            "format": "uuid",
            "nullable": true,
            "description": "Share a playlist (exactly one of mediaItemId or playlistId must be set)"
          }
        }
      },
      "ShareResponseDto": {
        "type": "object",
        "properties": {
          "shareId": {
            "type": "string",
            "format": "uuid"
          },
          "receiverEmail": {
            "type": "string",
            "format": "email"
          },
          "sharedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ShareDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "senderName": {
            "type": "string"
          },
          "receiverName": {
            "type": "string"
          },
          "sharedAt": {
            "type": "string",
            "format": "date-time"
          },
          "mediaItem": {
            "allOf": [{ "$ref": "#/components/schemas/MediaItemSummaryDto" }],
            "nullable": true
          },
          "playlistId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "playlistTitle": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "PagedShareDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/ShareDto"
            }
          },
          "totalCount": {
            "type": "integer"
          },
          "pageNumber": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          },
          "totalPages": {
            "type": "integer"
          }
        }
      },
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "format": "uuid"
          },
          "displayName": {
            "type": "string"
          },
          "bio": {
            "type": "string"
          },
          "avatarPath": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "UpdateProfileRequest": {
        "type": "object",
        "required": ["bio"],
        "properties": {
          "bio": {
            "type": "string"
          },
          "avatarPath": {
            "type": "string",
            "nullable": true
          }
        }
      },
      "NotificationDto": {
        "type": "object",
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid"
          },
          "type": {
            "type": "string",
            "description": "Notification type identifier (e.g. 'MediaShared', 'UserFollowed')"
          },
          "payloadJson": {
            "type": "string",
            "description": "JSON-encoded notification payload"
          },
          "isRead": {
            "type": "boolean"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "NotificationsPageDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/NotificationDto"
            }
          },
          "unreadCount": {
            "type": "integer"
          },
          "totalCount": {
            "type": "integer"
          },
          "pageNumber": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "FavoriteDto": {
        "type": "object",
        "properties": {
          "mediaItemId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds"
          },
          "fileType": {
            "type": "string"
          },
          "streamUrl": {
            "type": "string"
          },
          "createdAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "PagedFavoritesDto": {
        "type": "object",
        "properties": {
          "items": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/FavoriteDto"
            }
          },
          "totalCount": {
            "type": "integer"
          },
          "page": {
            "type": "integer"
          },
          "pageSize": {
            "type": "integer"
          }
        }
      },
      "ToggleFavoriteResponse": {
        "type": "object",
        "properties": {
          "isFavorited": {
            "type": "boolean"
          }
        }
      },
      "PlayHistoryDto": {
        "type": "object",
        "properties": {
          "mediaItemId": {
            "type": "string",
            "format": "uuid"
          },
          "title": {
            "type": "string"
          },
          "artist": {
            "type": "string"
          },
          "duration": {
            "type": "integer",
            "description": "Duration in seconds"
          },
          "fileType": {
            "type": "string"
          },
          "streamUrl": {
            "type": "string"
          },
          "playedAt": {
            "type": "string",
            "format": "date-time"
          }
        }
      },
      "ToggleFollowResponse": {
        "type": "object",
        "properties": {
          "isFollowing": {
            "type": "boolean"
          }
        }
      },
      "ProblemDetails": {
        "type": "object",
        "properties": {
          "type": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "status": {
            "type": "integer"
          },
          "detail": {
            "type": "string"
          },
          "errors": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "responses": {
      "Unauthorized": {
        "description": "Missing or invalid JWT token",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "BadRequest": {
        "description": "Validation error",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      },
      "NotFound": {
        "description": "Resource not found",
        "content": {
          "application/json": {
            "schema": {
              "$ref": "#/components/schemas/ProblemDetails"
            }
          }
        }
      }
    }
  },
  "tags": [
    {
      "name": "Auth",
      "description": "Authentication — register and login"
    },
    {
      "name": "Media",
      "description": "Media items — library, upload, streaming, search, trending"
    },
    {
      "name": "Playlists",
      "description": "Playlist management and track operations"
    },
    {
      "name": "Shares",
      "description": "Share media items or playlists with other users"
    },
    {
      "name": "Favorites",
      "description": "Toggle and retrieve favorited media items"
    },
    {
      "name": "Play History",
      "description": "Record plays and retrieve recent history"
    },
    {
      "name": "Follows",
      "description": "Follow / unfollow other users"
    },
    {
      "name": "Profile",
      "description": "User profile retrieval and update"
    },
    {
      "name": "Notifications",
      "description": "In-app notifications"
    }
  ],
  "paths": {
    "/api/auth/register": {
      "post": {
        "tags": ["Auth"],
        "summary": "Register a new user",
        "operationId": "Auth_Register",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/RegisterRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Registration successful — returns user info and JWT",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/RegisterResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          }
        }
      }
    },
    "/api/auth/login": {
      "post": {
        "tags": ["Auth"],
        "summary": "Authenticate an existing user",
        "operationId": "Auth_Login",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/LoginRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Login successful — returns user info, JWT, and expiry",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/LoginResponse"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/media": {
      "get": {
        "tags": ["Media"],
        "summary": "Get all media items (library)",
        "operationId": "Media_GetLibrary",
        "security": [],
        "responses": {
          "200": {
            "description": "List of all media items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MediaItemDto"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "tags": ["Media"],
        "summary": "Create a media item record (JSON body, no file upload)",
        "operationId": "Media_Create",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreateMediaItemRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Media item created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MediaItemDto"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/media/upload": {
      "post": {
        "tags": ["Media"],
        "summary": "Upload a media file (multipart/form-data)",
        "operationId": "Media_Upload",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "required": ["file", "title", "artist"],
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary",
                    "description": "Audio or video file (.mp3, .wav, .mp4, .webm, etc.)"
                  },
                  "title": {
                    "type": "string"
                  },
                  "artist": {
                    "type": "string"
                  },
                  "genre": {
                    "type": "string",
                    "nullable": true
                  },
                  "description": {
                    "type": "string",
                    "nullable": true
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Upload successful — returns the new media item ID (UUID)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "string",
                  "format": "uuid"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/media/{id}/stream": {
      "get": {
        "tags": ["Media"],
        "summary": "Stream a media file (supports HTTP Range requests)",
        "operationId": "Media_Stream",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string",
              "format": "uuid"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Audio or video byte stream",
            "content": {
              "audio/mpeg": {
                "schema": { "type": "string", "format": "binary" }
              },
              "video/mp4": {
                "schema": { "type": "string", "format": "binary" }
              },
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      }
    },
    "/api/media/search": {
      "get": {
        "tags": ["Media"],
        "summary": "Search media items by term and/or file type",
        "operationId": "Media_Search",
        "security": [],
        "parameters": [
          {
            "name": "term",
            "in": "query",
            "schema": { "type": "string" },
            "required": false,
            "description": "Search term (matches title, artist, genre)"
          },
          {
            "name": "fileType",
            "in": "query",
            "schema": { "$ref": "#/components/schemas/MediaFileType" },
            "required": false,
            "description": "Filter by file type"
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "default": 1 }
          },
          {
            "name": "pageSize",
            "in": "query",
            "schema": { "type": "integer", "default": 20 }
          }
        ],
        "responses": {
          "200": {
            "description": "Paged search results",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PagedMediaItemSummary"
                }
              }
            }
          }
        }
      }
    },
    "/api/media/trending": {
      "get": {
        "tags": ["Media"],
        "summary": "Get trending media items",
        "operationId": "Media_GetTrending",
        "security": [],
        "responses": {
          "200": {
            "description": "List of trending media items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/MediaItemSummaryDto"
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/playlists": {
      "post": {
        "tags": ["Playlists"],
        "summary": "Create a new playlist",
        "operationId": "Playlists_Create",
        "security": [{ "BearerAuth": [] }],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/CreatePlaylistRequest"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Playlist created",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaylistDto"
                }
              }
            }
          },
          "400": {
            "$ref": "#/components/responses/BadRequest"
          },
          "401": {
            "$ref": "#/components/responses/Unauthorized"
          }
        }
      }
    },
    "/api/playlists/{id}": {
      "get": {
        "tags": ["Playlists"],
        "summary": "Get a playlist by ID (with its tracks)",
        "operationId": "Playlists_GetById",
        "security": [],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "200": {
            "description": "Playlist detail with track list",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PlaylistDetailDto"
                }
              }
            }
          },
          "404": {
            "$ref": "#/components/responses/NotFound"
          }
        }
      },
      "delete": {
        "tags": ["Playlists"],
        "summary": "Delete a playlist owned by the authenticated user",
        "operationId": "Playlists_Delete",
        "security": [{ "BearerAuth": [] }],
        "parameters": [
          {
            "name": "id",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "responses": {
          "204": { "description": "Playlist deleted" },
          "401": { "$ref": "#/components/responses/Unauthorized" },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      }
    },
